#!/usr/bin/env bash
# bin/status - Check bootstrap completion status
#
# Usage:
#   status [--manifest <profile>]
#
# Run this after launch to see whether provisioning finished successfully.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "${SCRIPT_DIR}")"

MANIFEST="full-dev"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --manifest) MANIFEST="$2"; shift 2 ;;
        *) echo "Usage: status [--manifest <profile>]" >&2; exit 1 ;;
    esac
done

MANIFEST_FILE="${REPO_ROOT}/manifests/${MANIFEST}.env"
MARKER_DIR="/var/lib/ec2-init/markers"
BOOTSTRAP_LOG="/var/log/ec2-init/bootstrap.log"
LOG_DIR="/var/log/ec2-init"

# ── Colours ───────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; RESET='\033[0m'
ok()   { echo -e "  ${GREEN}✓${RESET}  $*"; }
fail() { echo -e "  ${RED}✗${RESET}  $*"; }
warn() { echo -e "  ${YELLOW}~${RESET}  $*"; }

echo ""
echo "  ec2-init status  (manifest: ${MANIFEST})"
echo "  ────────────────────────────────────────"

# ── cloud-init ────────────────────────────────────────────────────────────────
echo ""
echo "  cloud-init"
CI_STATUS="$(cloud-init status 2>/dev/null | awk '{print $NF}')"
case "${CI_STATUS}" in
    done)    ok "cloud-init: done" ;;
    running) warn "cloud-init: still running" ;;
    error)   fail "cloud-init: error — check /var/log/cloud-init-output.log" ;;
    *)       warn "cloud-init: ${CI_STATUS:-unknown}" ;;
esac

# ── Modules ───────────────────────────────────────────────────────────────────
echo ""
echo "  Modules"

if [[ ! -f "${MANIFEST_FILE}" ]]; then
    warn "Manifest not found: ${MANIFEST_FILE}"
else
    source "${MANIFEST_FILE}" 2>/dev/null

    TOTAL=0
    DONE=0
    MISSING=()

    while IFS= read -r module; do
        [[ -z "${module}" || "${module}" =~ ^[[:space:]]*# ]] && continue
        module="$(echo "${module}" | tr -d '[:space:]')"
        [[ -z "${module}" ]] && continue

        TOTAL=$(( TOTAL + 1 ))
        if [[ -f "${MARKER_DIR}/${module}.done" ]]; then
            TS="$(cat "${MARKER_DIR}/${module}.done" 2>/dev/null)"
            ok "${module}  ${YELLOW}(${TS})${RESET}"
            DONE=$(( DONE + 1 ))
        else
            fail "${module}  — not complete"
            MISSING+=("${module}")
        fi
    done <<< "${MODULE_LIST}"

    echo ""
    if [[ "${DONE}" -eq "${TOTAL}" ]]; then
        echo -e "  ${GREEN}All ${TOTAL}/${TOTAL} modules complete.${RESET}"
    else
        echo -e "  ${RED}${DONE}/${TOTAL} modules complete.${RESET} Failed: ${MISSING[*]}"
    fi
fi

# ── Logs ──────────────────────────────────────────────────────────────────────
echo ""
echo "  Logs"
if [[ -f "${BOOTSTRAP_LOG}" ]]; then
    # Show the last status line from the bootstrap log
    LAST_EXIT="$(grep 'Exit code' "${BOOTSTRAP_LOG}" | tail -1)"
    if [[ -n "${LAST_EXIT}" ]]; then
        if echo "${LAST_EXIT}" | grep -q ': 0'; then
            ok "bootstrap exit code: 0"
        else
            fail "${LAST_EXIT}"
        fi
    else
        warn "bootstrap log exists but no exit code found yet"
    fi
    echo ""
    echo "  Tail of ${BOOTSTRAP_LOG}:"
    echo "  ────────────────────────────────────────"
    tail -5 "${BOOTSTRAP_LOG}" | sed 's/^/    /'
else
    warn "No bootstrap log found at ${BOOTSTRAP_LOG}"
fi

# ── Failed module logs ────────────────────────────────────────────────────────
if [[ "${#MISSING[@]:-0}" -gt 0 ]]; then
    echo ""
    echo "  Failed module logs"
    for module in "${MISSING[@]}"; do
        log="${LOG_DIR}/${module}.log"
        if [[ -f "${log}" ]]; then
            echo ""
            echo "  ── ${module}.log (last 10 lines) ──"
            tail -10 "${log}" | sed 's/^/    /'
        fi
    done
fi

echo ""
