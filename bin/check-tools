#!/usr/bin/env bash
# bin/check-tools - Verify all expected tools are installed and functional
#
# Runs independently of the module/marker system — checks the actual state
# of the machine against what the manifest expects.
#
# Usage:
#   check-tools [--manifest <profile>]
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "${SCRIPT_DIR}")"

MANIFEST="full-dev"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --manifest) MANIFEST="$2"; shift 2 ;;
        *) echo "Usage: check-tools [--manifest <profile>]" >&2; exit 1 ;;
    esac
done

# Source manifest for BREW_PACKAGES, BOOTSTRAP_USER, etc.
MANIFEST_FILE="${REPO_ROOT}/manifests/${MANIFEST}.env"
[[ -f "${MANIFEST_FILE}" ]] || { echo "Manifest not found: ${MANIFEST_FILE}" >&2; exit 1; }
# shellcheck source=/dev/null
source "${MANIFEST_FILE}"

BREW_USER="${BOOTSTRAP_USER:-ubuntu}"
BREW_PREFIX="${BREW_PREFIX:-/home/linuxbrew/.linuxbrew}"
NVM_DIR="/home/${BREW_USER}/.nvm"
SDKMAN_DIR="/home/${BREW_USER}/.sdkman"

# ── Helpers ───────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; RESET='\033[0m'
PASS=0; FAIL=0

ok()   { echo -e "  ${GREEN}✓${RESET}  $*"; PASS=$(( PASS + 1 )); }
fail() { echo -e "  ${RED}✗${RESET}  $*"; FAIL=$(( FAIL + 1 )); }
warn() { echo -e "  ${YELLOW}~${RESET}  $*"; }
hdr()  { echo ""; echo "  ── $* ──"; }

check_cmd() {
    local label="$1" cmd="$2"
    if ver="$(eval "${cmd}" 2>/dev/null | head -1)"; then
        ok "${label}: ${ver}"
    else
        fail "${label}: not found or not functional"
    fi
}

check_apt() {
    local pkg="$1"
    if dpkg -s "${pkg}" &>/dev/null; then
        ok "apt: ${pkg}"
    else
        fail "apt: ${pkg} — NOT installed"
    fi
}

check_brew_formula() {
    local formula="$1"
    local bin="${BREW_PREFIX}/bin/${formula}"
    # Some formulae install under a different binary name
    case "${formula}" in
        ripgrep)    bin="${BREW_PREFIX}/bin/rg" ;;
        git-delta)  bin="${BREW_PREFIX}/bin/delta" ;;
        go)         bin="${BREW_PREFIX}/bin/go" ;;
        gh)         bin="${BREW_PREFIX}/bin/gh" ;;
    esac
    if [[ -x "${bin}" ]]; then
        ver="$(sudo -u "${BREW_USER}" "${bin}" --version 2>/dev/null | head -1 || echo '')"
        ok "brew: ${formula}  ${YELLOW}(${ver})${RESET}"
    else
        fail "brew: ${formula} — NOT installed (expected at ${bin})"
    fi
}

# ── Header ────────────────────────────────────────────────────────────────────
echo ""
echo "  check-tools  (manifest: ${MANIFEST})"
echo "  ══════════════════════════════════════"

# ── System (apt) ──────────────────────────────────────────────────────────────
hdr "System packages"
for pkg in curl wget vim git unzip zip ca-certificates build-essential; do
    check_apt "${pkg}"
done

# ── Docker ────────────────────────────────────────────────────────────────────
hdr "Docker"
if command -v docker &>/dev/null; then
    ok "docker engine: $(docker version --format '{{.Server.Version}}' 2>/dev/null)"
    ok "docker compose: $(docker compose version --short 2>/dev/null)"
    ok "docker buildx: $(docker buildx version 2>/dev/null | head -1)"
    systemctl is-active --quiet docker && ok "dockerd: running" || fail "dockerd: not running"
    groups "${BREW_USER}" | grep -q '\bdocker\b' \
        && ok "${BREW_USER} in docker group" \
        || fail "${BREW_USER} NOT in docker group"
else
    fail "docker: not installed"
fi

# ── Python ────────────────────────────────────────────────────────────────────
hdr "Python"
check_cmd "python3" "python3 --version"
check_cmd "pip3"    "pip3 --version"
python3 -c "import venv" 2>/dev/null && ok "venv: OK" || fail "venv: not functional"

# ── zsh ───────────────────────────────────────────────────────────────────────
hdr "zsh"
check_cmd "zsh" "zsh --version"
ZSH_PATH="$(command -v zsh 2>/dev/null)"
CURRENT_SHELL="$(getent passwd "${BREW_USER}" | cut -d: -f7)"
[[ "${CURRENT_SHELL}" == "${ZSH_PATH}" ]] \
    && ok "default shell: zsh" \
    || fail "default shell: ${CURRENT_SHELL} (expected ${ZSH_PATH})"

# ── oh-my-zsh ─────────────────────────────────────────────────────────────────
hdr "oh-my-zsh"
OMZ_DIR="/home/${BREW_USER}/.oh-my-zsh"
[[ -f "${OMZ_DIR}/oh-my-zsh.sh" ]] \
    && ok "oh-my-zsh: installed" \
    || fail "oh-my-zsh: not found at ${OMZ_DIR}"
[[ -f "/home/${BREW_USER}/.zshrc" ]] \
    && ok ".zshrc: present" \
    || fail ".zshrc: missing"

# ── Homebrew ──────────────────────────────────────────────────────────────────
hdr "Homebrew"
if [[ -x "${BREW_PREFIX}/bin/brew" ]]; then
    ok "brew: $(sudo -u "${BREW_USER}" "${BREW_PREFIX}/bin/brew" --version 2>/dev/null | head -1)"
else
    fail "brew: not found at ${BREW_PREFIX}/bin/brew"
fi

# ── Brew packages (from manifest BREW_PACKAGES) ───────────────────────────────
hdr "Brew packages  (from BREW_PACKAGES in ${MANIFEST}.env)"
INSTALLED_FORMULAE="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" \
    "${BREW_PREFIX}/bin/brew" list --formula 2>/dev/null | tr '\n' ' ')"

for formula in ${BREW_PACKAGES}; do
    check_brew_formula "${formula}"
done

# ── SDKMAN + Java ─────────────────────────────────────────────────────────────
hdr "SDKMAN / Java"
if [[ -s "${SDKMAN_DIR}/bin/sdkman-init.sh" ]]; then
    SDKMAN_VER="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" bash -c "
        export SDKMAN_DIR=\"${SDKMAN_DIR}\"
        source \"${SDKMAN_DIR}/bin/sdkman-init.sh\"
        sdk version 2>/dev/null | head -1
    " 2>/dev/null)"
    ok "sdkman: ${SDKMAN_VER}"
    JAVA_VER="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" bash -c "
        export SDKMAN_DIR=\"${SDKMAN_DIR}\"
        source \"${SDKMAN_DIR}/bin/sdkman-init.sh\"
        java -version 2>&1 | head -1
    " 2>/dev/null)"
    ok "java: ${JAVA_VER}"
else
    fail "sdkman: not installed"
fi

# ── NVM + Node ────────────────────────────────────────────────────────────────
hdr "NVM / Node"
if [[ -s "${NVM_DIR}/nvm.sh" ]]; then
    NODE_VER="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" bash -c "
        export NVM_DIR=\"${NVM_DIR}\"
        source \"\${NVM_DIR}/nvm.sh\"
        node --version 2>/dev/null
    " 2>/dev/null)"
    NPM_VER="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" bash -c "
        export NVM_DIR=\"${NVM_DIR}\"
        source \"\${NVM_DIR}/nvm.sh\"
        npm --version 2>/dev/null
    " 2>/dev/null)"
    ok "node: ${NODE_VER}"
    ok "npm: ${NPM_VER}"
else
    fail "nvm: not installed"
fi

# ── Codex ─────────────────────────────────────────────────────────────────────
hdr "Codex CLI"
CODEX_VER="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" bash -c "
    export NVM_DIR=\"${NVM_DIR}\"
    source \"\${NVM_DIR}/nvm.sh\"
    codex --version 2>/dev/null || npm list -g @openai/codex 2>/dev/null | grep codex | head -1
" 2>/dev/null)"
[[ -n "${CODEX_VER}" ]] && ok "codex: ${CODEX_VER}" || fail "codex: not installed"

# ── Claude Code ───────────────────────────────────────────────────────────────
hdr "Claude Code"
CLAUDE_VER="$(sudo -u "${BREW_USER}" HOME="/home/${BREW_USER}" bash -c "
    export NVM_DIR=\"${NVM_DIR}\"
    source \"\${NVM_DIR}/nvm.sh\"
    claude --version 2>/dev/null
" 2>/dev/null)"
[[ -n "${CLAUDE_VER}" ]] && ok "claude: ${CLAUDE_VER}" || fail "claude: not installed"

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo "  ══════════════════════════════════════"
TOTAL=$(( PASS + FAIL ))
if [[ "${FAIL}" -eq 0 ]]; then
    echo -e "  ${GREEN}All ${TOTAL} checks passed.${RESET}"
else
    echo -e "  ${GREEN}${PASS} passed${RESET}  ${RED}${FAIL} failed${RESET}  (${TOTAL} total)"
fi
echo ""
