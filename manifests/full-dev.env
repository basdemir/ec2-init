# manifests/full-dev.env - Full developer profile
# Use this for developer workstations and interactive dev instances.

BOOTSTRAP_USER="ubuntu"
BREW_PREFIX="/home/linuxbrew/.linuxbrew"

MODULE_LIST="
base
docker
python
zsh
ohmyzsh
brew
devtools
sdkman
nvm
codex
claudecode
"

# ── Module config ─────────────────────────────────────────────────────────────
DOCKER_VERSION=""               # empty = latest stable
ZSH_SET_DEFAULT_SHELL="true"

OHMYZSH_THEME="bira"
OHMYZSH_PLUGINS="git docker fzf zsh-autosuggestions zsh-syntax-highlighting"

# Pure tools only — shell plugins are managed as oh-my-zsh custom plugins above
# golang (go) included here per "golang with brew"
BREW_PACKAGES="fzf ripgrep bat lazygit git-delta go gh"

# ── Python config ─────────────────────────────────────────────────────────────
PYTHON_EXTRA_PACKAGES=""        # e.g. "httpie black"

# ── SDKMAN / Java config ──────────────────────────────────────────────────────
SDKMAN_JAVA_VERSION="25-tem"    # Temurin JDK 25; check 'sdk list java' for exact identifiers

# ── NVM / Node config ─────────────────────────────────────────────────────────
NVM_VERSION="v0.40.1"
NODE_VERSION="24"               # major version; nvm resolves to latest 24.x LTS patch

# Optional: pin brew installer SHA256 for reproducibility
# Update this when Homebrew publishes a new installer version.
# Leave empty to always use HEAD (acceptable for most use cases).
BREW_INSTALL_SHA256=""
