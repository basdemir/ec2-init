# manifests/minimal.env - Minimal profile: base OS tools only
# Use this for utility/monitoring instances that need Docker but not a full dev env.

BOOTSTRAP_USER="ubuntu"
BREW_PREFIX="/home/linuxbrew/.linuxbrew"

MODULE_LIST="
docker
zsh
"

# ── Module config ─────────────────────────────────────────────────────────────
DOCKER_VERSION=""               # empty = latest stable from official repo
ZSH_SET_DEFAULT_SHELL="true"
