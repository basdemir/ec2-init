# manifests/test-container.env - Container-safe test profile
# Excludes the docker module (needs systemd, unavailable in containers).
# Use this for local testing with: docker run ubuntu:24.04

BOOTSTRAP_USER="testuser"
BREW_PREFIX="/home/linuxbrew/.linuxbrew"

MODULE_LIST="
zsh
ohmyzsh
brew
devtools
"

ZSH_SET_DEFAULT_SHELL="true"

OHMYZSH_THEME="bira"
OHMYZSH_PLUGINS="git zsh-autosuggestions zsh-syntax-highlighting"

BREW_PACKAGES="fzf ripgrep bat jq"
BREW_INSTALL_SHA256=""
