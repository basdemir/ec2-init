# manifests/backend.env - Backend profile: Docker + shell + base brew tools
# Use this for API servers, workers, or CI runner instances.

BOOTSTRAP_USER="ubuntu"
BREW_PREFIX="/home/linuxbrew/.linuxbrew"

MODULE_LIST="
base
docker
python
zsh
ohmyzsh
brew
devtools
sdkman
nvm
"

# ── Module config ─────────────────────────────────────────────────────────────
DOCKER_VERSION=""               # empty = latest stable
ZSH_SET_DEFAULT_SHELL="true"

OHMYZSH_THEME="bira"
OHMYZSH_PLUGINS="git docker zsh-autosuggestions zsh-syntax-highlighting"

# Pure tools only — shell plugins are managed as oh-my-zsh custom plugins
BREW_PACKAGES="fzf ripgrep bat gh"

# ── Python config ─────────────────────────────────────────────────────────────
PYTHON_EXTRA_PACKAGES=""

# ── SDKMAN / Java config ──────────────────────────────────────────────────────
SDKMAN_JAVA_VERSION="25-tem"

# ── NVM / Node config ─────────────────────────────────────────────────────────
NVM_VERSION="v0.40.1"
NODE_VERSION="24"
